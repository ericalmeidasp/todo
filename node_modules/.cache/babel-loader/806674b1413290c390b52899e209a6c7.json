{"remainingRequest":"/home/eric/Documentos/Apps/todo/node_modules/babel-loader/lib/index.js!/home/eric/Documentos/Apps/todo/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/eric/Documentos/Apps/todo/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/eric/Documentos/Apps/todo/src/views/Todo.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/eric/Documentos/Apps/todo/src/views/Todo.vue","mtime":1615346890349},{"path":"/home/eric/Documentos/Apps/todo/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/eric/Documentos/Apps/todo/node_modules/babel-loader/lib/index.js","mtime":315532800000},{"path":"/home/eric/Documentos/Apps/todo/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/eric/Documentos/Apps/todo/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Todo.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgEA,eAAA;AACA,EAAA,IAAA,EAAA,MADA;AAEA,EAAA,IAFA,kBAEA;AACA,WAAA;AACA,MAAA,YAAA,EAAA,EADA;AAEA,MAAA,iBAAA,EAAA,KAFA;AAGA,MAAA,KAAA,EAAA,CACA;AACA;AACA;AACA;AACA;AALA;AAHA,KAAA;AAWA,GAdA;AAgBA,EAAA,OAhBA,qBAgBA;AACA,QAAA,YAAA,CAAA,OAAA,CAAA,OAAA,CAAA,EAAA;AACA,UAAA;AACA,aAAA,KAAA,GAAA,IAAA,CAAA,KAAA,CAAA,YAAA,CAAA,OAAA,CAAA,OAAA,CAAA,CAAA;AACA,OAFA,CAEA,OAAA,CAAA,EAAA;AACA,QAAA,YAAA,CAAA,UAAA,CAAA,OAAA;AACA;AACA;AACA,GAxBA;AA2BA,EAAA,OAAA,EAAA;AACA,IAAA,QADA,oBACA,EADA,EACA;AACA,UAAA,IAAA,GAAA,KAAA,KAAA,CAAA,MAAA,CAAA,UAAA,IAAA;AAAA,eAAA,IAAA,CAAA,EAAA,KAAA,EAAA;AAAA,OAAA,EAAA,CAAA,CAAA;AACA,MAAA,IAAA,CAAA,IAAA,GAAA,CAAA,IAAA,CAAA,IAAA;AACA,WAAA,SAAA;AACA,KALA;AAOA,IAAA,UAPA,sBAOA,EAPA,EAOA;AACA,WAAA,KAAA,GAAA,KAAA,KAAA,CAAA,MAAA,CAAA,UAAA,IAAA;AAAA,eAAA,IAAA,CAAA,EAAA,KAAA,EAAA;AAAA,OAAA,CAAA;AACA,WAAA,SAAA;AACA,KAVA;AAYA,IAAA,OAZA,qBAYA;AAEA,UAAA,CAAA,KAAA,YAAA,EAAA;AACA,aAAA,iBAAA,GAAA,IAAA;AACA,OAFA,MAIA;AACA,YAAA,OAAA,GAAA;AACA,UAAA,EAAA,EAAA,IAAA,CAAA,GAAA,EADA;AAEA,UAAA,KAAA,EAAA,KAAA,YAFA;AAGA,UAAA,IAAA,EAAA;AAHA,SAAA;AAKA,aAAA,KAAA,CAAA,IAAA,CAAA,OAAA;AACA,aAAA,YAAA,GAAA,EAAA;AACA,aAAA,iBAAA,GAAA,KAAA;AACA,aAAA,SAAA;AACA;AACA,KA7BA;AA+BA,IAAA,SA/BA,uBA+BA;AACA,UAAA,MAAA,GAAA,IAAA,CAAA,SAAA,CAAA,KAAA,KAAA,CAAA;AACA,MAAA,YAAA,CAAA,OAAA,CAAA,OAAA,EAAA,MAAA;AACA;AAlCA;AA3BA,CAAA","sourcesContent":["<template>\n  <div class=\"home\">\n    <v-text-field\n            v-model=\"newTaskTitle\"\n            @click:append=\"addTask\"\n            @keyup.enter=\"addTask\"\n            class=\"pa-3\"\n            outlined\n            label=\"Adicionar Tarefa\"\n            append-icon=\"mdi-playlist-plus\"\n            hide-details\n            clearable\n            notnull\n          ></v-text-field>\n    <v-list class=\"pt-0\"\n      flat\n    >\n      <div\n      v-for=\"task in tasks\"\n        :key=\"task.id\"\n      >\n        <v-list-item\n          @click=\"doneTask(task.id)\"\n          :class=\"{ 'blue lighten-5' : task.done }\"\n        >\n          <template v-slot:default>\n            <v-list-item-action>\n              <v-checkbox :input-value=\"task.done\"></v-checkbox>\n            </v-list-item-action>\n\n            <v-list-item-content>\n              <v-list-item-title\n              :class=\"{ 'text-decoration-line-through' : task.done }\"\n              >\n              {{ task.title }} \n              </v-list-item-title>\n            </v-list-item-content>\n          <v-list-item-action>\n            <v-btn \n            @click.stop=\"deleteTask(task.id)\"\n            icon\n            >\n             <v-icon color=\"primary lighten-1\">mdi-delete</v-icon>\n            </v-btn>\n        </v-list-item-action>\n          </template>\n        </v-list-item>\n        <v-divider></v-divider>\n      </div>\n\n     </v-list>\n  <v-alert\n      dense\n      outlined\n      type=\"error\"\n      v-if=\"newTaskTitleAlert\"\n    >\n      Por gentileza, preencha a tarefa.\n    </v-alert>\n  \n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'Todo',\n  data() {\n    return {\n      newTaskTitle: '',\n      newTaskTitleAlert: false,\n      tasks: [\n        // {\n        // id: 1,\n        // title: 'Sou uma tarefa',\n        // done: false\n        // },\n      ]\n    }\n  },\n\n  mounted() {\n    if (localStorage.getItem('tasks')) {\n      try {\n        this.tasks = JSON.parse(localStorage.getItem('tasks'));\n      } catch(e) {\n        localStorage.removeItem('tasks');\n      }\n    }\n  },\n\n  \n  methods: {\n    doneTask(id) {\n      let task = this.tasks.filter(task => task.id === id) [0]\n      task.done = !task.done\n      this.saveNotes()\n    },\n\n    deleteTask(id) {\n      this.tasks = this.tasks.filter(task => task.id !== id)\n      this.saveNotes()\n    },\n\n    addTask() {\n\n      if(!this.newTaskTitle) {\n      this.newTaskTitleAlert = true\n      }\n\n      else {\n      let newTask = {\n        id: Date.now(),\n        title: this.newTaskTitle,\n        done: false\n      }\n      this.tasks.push(newTask)\n      this.newTaskTitle = ''\n      this.newTaskTitleAlert = false\n      this.saveNotes()\n      }\n    },\n\n    saveNotes() {\n      const parsed = JSON.stringify(this.tasks)\n      localStorage.setItem('tasks', parsed)\n    }\n    \n  }\n}\n</script>\n"],"sourceRoot":"src/views"}]}